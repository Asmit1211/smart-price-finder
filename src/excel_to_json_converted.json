# Re-create the JSON structure with correct column mapping
result = []
for index, row in merged_df.iterrows():
    product_entry = {
        "product_name": row['Product'].strip(),
        "platforms": {
            "blinkit": {
                "link": row['blinkit'] if pd.notnull(row['blinkit']) else None,
                "price": int(row['Blinkit']) if pd.notnull(row['Blinkit']) else None
            },
            "flipkart_minutes": {
                "link": row['flickart minutes'] if pd.notnull(row['flickart minutes']) else None,
                "price": int(row['flipcart minute']) if pd.notnull(row['flipcart minute']) else None
            },
            "instamart": {
                "link": row['instmart'] if pd.notnull(row['instmart']) else None,
                "price": int(row['instamart']) if pd.notnull(row['instamart']) else None
            },
            "zepto": {
                "link": row['zepto_y'] if pd.notnull(row['zepto_y']) else None,
                "price": int(row['zepto_x']) if pd.notnull(row['zepto_x']) else None
            }
        }
    }
    result.append(product_entry)

# Save the final JSON
with open('product_info_merged.json', 'w') as f:
    json.dump(result, f, indent=4)

print(f"Final JSON file 'product_info_merged.json' created successfully with {len(result)} items.")
# Print first two entries for confirmation
print(json.dumps(result[:2], indent=4))

