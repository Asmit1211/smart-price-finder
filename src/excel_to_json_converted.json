# Standardize product names for merging
df_links['product_clean'] = df_links['product'].astype(str).str.strip().str.lower()
df_prices['product_clean'] = df_prices['Product'].astype(str).str.strip().str.lower()

# Merge the dataframes
merged_df = pd.merge(df_prices, df_links, on='product_clean', how='inner')

# Create the JSON structure
result = []
for index, row in merged_df.iterrows():
    product_data = {
        "product_name": row['Product'],
        "platforms": {
            "blinkit": {
                "link": row['blinkit'] if pd.notnull(row['blinkit']) else None,
                "price": int(row['Blinkit']) if pd.notnull(row['Blinkit']) else None
            },
            "flipkart": {
                "link": row['flickart minutes'] if pd.notnull(row['flickart minutes']) else None,
                "price": int(row['flipcart minute']) if pd.notnull(row['flipcart minute']) else None
            },
            "instamart": {
                "link": row['instmart'] if pd.notnull(row['instmart']) else None,
                "price": int(row['instamart']) if pd.notnull(row['instamart']) else None
            },
            "zepto": {
                "link": row['zepto'] if pd.notnull(row['zepto']) else None,
                "price": int(row['zepto_x']) if pd.notnull(row['zepto_x']) else None # Note: zepto is in both, so it became zepto_x and zepto_y
            }
        }
    }
    result.append(product_data)

# Save to JSON file
with open('product_data.json', 'w') as f:
    json.dump(result, f, indent=4)

print(f"Successfully created product_data.json with {len(result)} items.")
# Print first item to verify
print(json.dumps(result[0], indent=4))

